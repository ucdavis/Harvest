@model Harvest.Web.Models.ReportModels.UnbilledExpensesReportModel
@{
    ViewData["Title"] = "Unbilled Expenses";
}

<div>
    <div>
        <h1>Approved Unbilled Expenses for Team: @Model.TeamName</h1>
        <p>This report shows each approved unbilled expense with its related project.</p>
    </div>
</div>

<table id="unbilled-expenses-report" class="table harvest-table">
    <thead>
        <tr>
            <th>Project</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Activity)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Type)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Description)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Quantity)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Markup)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].IsPassthrough)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Account)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].RateName)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Price)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Total)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].CreatedByName)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].CreatedOnLocal)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].Approved)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].ApprovedByName)</th>
            <th>@Html.DisplayNameFor(model => model.Expenses[0].ApprovedOnLocal)</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Expenses.Any())
        {
            <tr>
                <td colspan="16">No approved unbilled expenses found for this team.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Expenses)
            {
                <tr>
                    <td>
                        <a href=@($"/{Model.Slug}/project/details/{item.ProjectId}") target="_blank">
                            @item.ProjectName (@item.ProjectId)
                        </a>
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Activity)</td>
                    <td>@Html.DisplayFor(modelItem => item.Type)</td>
                    <td>@Html.DisplayFor(modelItem => item.Description)</td>
                    <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                    <td>@(item.Markup ? "Yes" : "No")</td>
                    <td>@(item.IsPassthrough ? "Yes" : "No")</td>
                    <td>@Html.DisplayFor(modelItem => item.Account)</td>
                    <td>@Html.DisplayFor(modelItem => item.RateName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Price)</td>
                    <td>@Html.DisplayFor(modelItem => item.Total)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedByName)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedOnLocal)</td>
                    <td>@(item.Approved ? "Yes" : "No")</td>
                    <td>@Html.DisplayFor(modelItem => item.ApprovedByName)</td>
                    <td>@Html.DisplayFor(modelItem => item.ApprovedOnLocal)</td>
                </tr>
            }
        }
    </tbody>
</table>

@section Styles
{
    @{
        await Html.RenderPartialAsync("_ReportStylesPartial");
    }
    @{
        await Html.RenderPartialAsync("_FaStylesPartial");
    }
}

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ReportScriptsPartial");
    }

    <script type="text/javascript">
        function getExportTimestamp() {
            var now = new Date();
            var pad = function (value) { return value.toString().padStart(2, '0'); };

            return now.getFullYear().toString() +
                pad(now.getMonth() + 1) +
                pad(now.getDate());
        }

        function getExportFileName() {
            return 'Harvest-@Model.Slug-UnbilledExpenses-' + getExportTimestamp();
        }

        var table = $('#unbilled-expenses-report').DataTable({
            "dom": 'lBfrtip',
            "order": [[0, "asc"], [11, "asc"]],
            columnDefs: [{
                type: "num-fmt",
                targets: [4, 8, 9]
            },
            {
                type: "date",
                targets: [11, 14]
            }],
            buttons: [
                {
                    extend: 'copyHtml5', className: 'btn-primary btn-sm', init: function (api, node, config) {
                        $(node).removeClass('btn-secondary')
                    }
                },
                {
                    extend: 'excelHtml5',
                    filename: getExportFileName,
                    className: 'btn-primary btn-sm', init: function (api, node, config) {
                        $(node).removeClass('btn-secondary')
                    }
                },
                {
                    extend: 'csvHtml5',
                    filename: getExportFileName,
                    className: 'btn-primary btn-sm', init: function (api, node, config) {
                        $(node).removeClass('btn-secondary')
                    }
                },
                {
                    extend: 'print', className: 'btn-primary btn-sm', init: function (api, node, config) {
                        $(node).removeClass('btn-secondary')
                    }
                },
            ]
        });
    </script>
}
